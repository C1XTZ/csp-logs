---
// @ts-ignore
import config from 'virtual:starlight/user-config';
// @ts-ignore
import type { StarlightIcon } from '@astrojs/starlight/components/Icons';
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import Search from 'starlight-theme-black/overrides/Search.astro';
import ThemeSelect from 'starlight-theme-black/overrides/ThemeSelect.astro';
import SiteTitle from 'starlight-theme-black/overrides/SiteTitle.astro';
import { Icon } from '@astrojs/starlight/components';
import NavBar from './theme/NavBar.astro';
import MobileMenuToggle from './theme/MobileMenuToggle.astro';

const shouldRenderSearch = config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
const links = config.social || [];
---

<div class="site-title-wrapper">
    <SiteTitle />
    <NavBar />
</div>
<MobileMenuToggle />
<div class="header-right">
    {shouldRenderSearch && <Search />}
    <nav class="header-nav">
        <div class="social-icons">
            {
                links.map(({ label, href, icon }: { label: string; href: string; icon: StarlightIcon }) => (
                    <a href={href} rel="me" class="sl-flex button" data-variant="ghost">
                        <span class="sr-only">{label}</span>
                        <Icon name={icon} />
                    </a>
                ))
            }
            <a href="https://acstuff.club/patch/" rel="me" class="sl-flex button" data-variant="ghost">
                <span class="sr-only">Website</span>
                <span class="custom-icon"></span>
            </a>
        </div>
        <div>
            <ThemeSelect />
        </div>
        <div>
            <LanguageSelect />
        </div>
    </nav>
</div>
<style>
    .site-title-wrapper {
        display: none;
        margin-right: 1rem;
    }
    @media (min-width: 768px) {
        .site-title-wrapper {
            display: flex;
        }
    }
    .header-right {
        gap: 0.5rem;
        justify-content: space-between;
        align-items: center;
        flex: 1 1 0%;
        display: flex;
    }
    @media (min-width: 768px) {
        .header-right {
            justify-content: flex-end;
        }
    }
    .header-nav {
        gap: 0.125rem;
        align-items: center;
        display: flex;
    }
    .social-icons a {
        color: inherit;
    }
    .custom-icon {
        display: inline-block;
        width: 1em;
        height: 1em;
        background-color: currentColor;
        mask: url(/favicon.svg) no-repeat center / contain;
        -webkit-mask: url(/favicon.svg) no-repeat center / contain;
    }
</style>

<script>
    // Adds timeAgo for all [data-timeago] elements including sidebar badges
    import { timeAgo } from '../ts/timeAgo.ts';
    import versions from '../data/versions.json';

    const flat = versions.groups.flat();
    const latestPreview = flat.find((v) => v.isPreview === true)?.published ?? null;
    const latestPublic = flat.find((v) => v.isPreview === false)?.published ?? null;
    const publishedByPath = new Map(flat.filter((v) => Boolean(v.published)).map((v) => [normalizePath(v.link), v.published as string]));

    function normalizePath(href: string) {
        return href.replace(/^https?:\/\/[^/]+/i, '').replace(/^\/csp-logs(?=\/|$)/, '');
    }

    function applyTimeAgo() {
        const previewBadge = document.querySelector("a[href$='/latest/preview'] .entry-badge");
        const publicBadge = document.querySelector("a[href$='/latest/public'] .entry-badge");
        if (previewBadge && latestPreview) previewBadge.setAttribute('data-timeago', latestPreview);
        if (publicBadge && latestPublic) publicBadge.setAttribute('data-timeago', latestPublic);

        document.querySelectorAll('.entry-badge').forEach((badgeEl) => {
            const badge = badgeEl as HTMLElement;
            if (badge.dataset.timeago) return;

            const href = badge.closest('a')?.getAttribute('href');
            if (!href || href.includes('/latest/')) return;

            const published = publishedByPath.get(normalizePath(href));
            if (published) badge.dataset.timeago = published;
        });

        document.querySelectorAll('[data-timeago]').forEach((el) => {
            (el as HTMLElement).textContent = timeAgo((el as HTMLElement).dataset.timeago ?? null);
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', applyTimeAgo, { once: true });
    } else {
        applyTimeAgo();
    }

    document.addEventListener('astro:page-load', applyTimeAgo);
</script>
