---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import versions from '../../data/versions.json';

export function getStaticPaths() {
    return [
        { params: { type: 'preview' }, props: { isPreview: true } },
        { params: { type: 'public' }, props: { isPreview: false } },
    ];
}

const { isPreview } = Astro.props;
const latest = versions.groups.flat().find((v) => v.isPreview === isPreview);

if (!latest) return new Response(null, { status: 404, statusText: 'Not found' });

const slug = latest.link.split('/').pop();

interface MarkdownDoc {
    Content: any;
    frontmatter: Record<string, any>;
    getHeadings: () => { depth: number; slug: string; text: string }[];
}

const pages = import.meta.glob<MarkdownDoc>('../../content/docs/*.md');
const { Content, frontmatter, getHeadings } = await pages[`../../content/docs/${slug}.md`]();
const headings = getHeadings();
---

<StarlightPage frontmatter={frontmatter as any} headings={headings}>
    <Content />
</StarlightPage>
